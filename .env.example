# Worky API。主 base（labor 等所有角色預設）走 /v1。
# base 與 secret 要成對（/qa-v1 模組有專屬 apiSecret，見 worky api/config/qa/main.php）：
#   /v1    → jXBZ95JIP4vQnUtHy5mVy0pVgOgdl2WbVebkbnGZhoGaiDXivWeY8WXAUl06mT7v
#   /qa-v1 → OIU3vazZSvOFS_gJ1445OiaAG7mH5iIFbeSkMQM6mofXuPzdnQTLWq1M5JqZZ0tx
WORKY_API_BASE=http://api.chaojun.worky.com.tw/v1
WORKY_API_SECRET=jXBZ95JIP4vQnUtHy5mVy0pVgOgdl2WbVebkbnGZhoGaiDXivWeY8WXAUl06mT7v
# 商家端可分流走 /qa-v1（QA 專用前綴，僅非 prod 註冊）：QA 模式 employer 請求帶 shop_id
# 即鎖定店鋪、不受「切換店鋪」影響（worky api/behaviors/ValidateSelectedShopBehavior.php）。
# labor 不能走 qa-v1：該模組配 SOURCE_WEB，APP 限定端點（job-apply 等）會被
# 後端來源白名單（ApiController::defaultEnabledSources）擋掉（403→10001）。
# 兩變數未設時沿用主 base/secret。
WORKY_EMPLOYER_API_BASE=http://api.chaojun.worky.com.tw/qa-v1
WORKY_EMPLOYER_API_SECRET=OIU3vazZSvOFS_gJ1445OiaAG7mH5iIFbeSkMQM6mofXuPzdnQTLWq1M5JqZZ0tx
WORKY_AUDIT_SMS_CODE=9527

# Worky DB（讀 notifications / s_contract_* 表做驗證）
WORKY_DB_HOST=192.168.101.213
WORKY_DB_PORT=3306
WORKY_DB_USER=root
WORKY_DB_PASS=1qaz2wsx#1506
WORKY_DB_NAME=worky_next_v31x
# 承攬制資料所在 DB（dev 環境 contract 與 job 分庫；留空則沿用 WORKY_DB_NAME）。
# 現況：job 流程在 worky_next_v31x，contract 由 API 寫到 worky_next_staging_v30x。
WORKY_CONTRACT_DB_NAME=worky_next_staging_v30x
# QA 看板資料庫（用例註冊 + 每次執行結果；與 worky 庫同 server，共用 host/port/user/pass）。
WORKY_QA_DB_NAME=worky_qa_dashboard

# 後台管理員（審核打工夥伴/店鋪用）預設 URL；帳號密碼不放這裡，改在看板「系統設置」頁編輯並持久化。
WORKY_BACKEND_BASE=https://backend.chaojun.worky.com.tw

# Headers
WORKY_PLATFORM=WebPC
WORKY_SDK_VERSION=1.0.0
WORKY_DEVICE_NAME=regression-runner

# DeepSeek（Layer ③ 用例分解器；OpenAI 相容介面）
# API key 申請：https://platform.deepseek.com → API keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
